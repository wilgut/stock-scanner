{
  "services": {
    "web": {
      "root": ".",
      "entrypoint": "app.py"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "web"
      }
    }
  ],
  "crons": [
    {
      "path": "/api/snapshot",
      "schedule": "35 21 * * 1-5"
    }
  ]
}
